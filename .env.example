# Runtime
MAYA_ENV=development
MAYA_DB_PATH=
MAYA_AUTH_SECRET=change-me-in-production
MAYA_AUTH_TTL_SECONDS=2592000
MAYA_AUTH_PASSWORDLESS=true
MAYA_BOOTSTRAP_ADMIN=true
MAYA_BOOTSTRAP_ADMIN_LOGIN=admin
MAYA_BOOTSTRAP_ADMIN_PASSWORD=admin
MAYA_BOOTSTRAP_ADMIN_DISPLAY=Administrator
MAYA_BOOTSTRAP_ADMIN_DJ_NAME=Admin

# CORS (comma-separated origins, ex: https://app.example.com,https://admin.example.com)
MAYA_CORS_ORIGINS=
MAYA_ALLOW_NULL_ORIGIN=true

# Library scan hardening
MAYA_ENABLE_LIBRARY_SCAN=true
MAYA_LIBRARY_SCAN_ROOT=
MAYA_LIBRARY_SCAN_MAX_FILES=400

# Password reset
MAYA_PASSWORD_RESET_TTL_SECONDS=1800
MAYA_ALLOW_DEBUG_RESET_TOKEN=true
MAYA_PUBLIC_APP_URL=https://your-maya-mixa-app.example.com
MAYA_OAUTH_STATE_TTL_SECONDS=600

# OAuth (Google / Apple)
MAYA_GOOGLE_CLIENT_ID=
MAYA_GOOGLE_CLIENT_SECRET=
MAYA_GOOGLE_REDIRECT_URI=
MAYA_APPLE_CLIENT_ID=
MAYA_APPLE_CLIENT_SECRET=
MAYA_APPLE_REDIRECT_URI=

# Music providers (library sync)
MAYA_SPOTIFY_CLIENT_ID=
MAYA_SPOTIFY_CLIENT_SECRET=
MAYA_SPOTIFY_REDIRECT_URI=
MAYA_DEEZER_APP_ID=
MAYA_DEEZER_APP_SECRET=
MAYA_DEEZER_REDIRECT_URI=
MAYA_APPLE_MUSIC_DEVELOPER_TOKEN=

# SMTP for password reset emails
MAYA_SMTP_HOST=
MAYA_SMTP_PORT=587
MAYA_SMTP_USER=
MAYA_SMTP_PASSWORD=
MAYA_SMTP_FROM=noreply@maya-mixa.local
MAYA_SMTP_USE_TLS=true
MAYA_SMTP_USE_SSL=false

# Optional OpenAI co-pilot
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Frontend / Electron runtime
MAYA_API_BASE=https://your-maya-mixa-api.example.com
MAYA_RELEASE_CHANNEL=stable
